@page "/shared-with-me"
@using ContosoDashboard.Services
@using ContosoDashboard.Models
@inject DocumentService DocumentService
@inject NavigationManager NavigationManager

<PageTitle>Compartido Conmigo</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Documentos Compartidos Conmigo</h1>
        </div>
    </div>

    @if (sharedDocuments == null)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    }
    else if (sharedDocuments.Count == 0)
    {
        <div class="alert alert-info">
            No hay documentos compartidos contigo.
        </div>
    }
    else
    {
        <DocumentList Documents="sharedDocuments" />
    }
</div>

@code {
    private List<Document> sharedDocuments = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            sharedDocuments = new List<Document>();
            // TODO: Llamar a DocumentService.GetSharedWithMeAsync una vez implementado
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
